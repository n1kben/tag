{
  "name": "tag-game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "three": "^0.172.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.4.0",
    "@types/three": "^0.172.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
